# SiteScope Environment Variables
# Copy to .env and fill in your values

# Required: OpenRouter API key (free tier works!)
OPENROUTER_API_KEY=sk-or-xxxxx

# Optional: Mapbox token for satellite/terrain tiles
# If not set, falls back to OpenStreetMap tiles
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxx

# Backend URL (for frontend to call)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
WMS_TIMEOUT=30
MAX_AGENTS_PARALLEL=5
